data/*/audio.mp3
data/*/audio.m4a
data/*/audio.opus
data/*/audio.ogg
*.webm
*.mp3
*.m4a
*.opus
*.wav
*.ogg

# ── Transcripts (auto-generated, large) ──────────────────────
